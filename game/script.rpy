# Вы можете расположить сценарий своей игры в этом файле.

default trust    = 0
default dark     = False
default evidence = False
default ending_5_unlocked = False

# Определение персонажей игры.
define a = Character('Алекс', color="#c8d3ff")
define r = Character('Рита',  color="#c8064dad")
define n = Character('Nul',  color="#000000ad")


# Игра начинается здесь:
label start:

    scene bg_office  # спрайты, звук и эффекты звуковые

    "В офисе компании «Киберщит» тихо. Алекс — единственный, кто остался в ночную смену. На столе перед ним — несколько пустых кружек из-под кофе."

    "Надпись на экране: ⚠ CRITICAL — Unauthorized access detected: ARGO-DB-CORE{w} Time to exfiltration: 02:58:00"

    a "(глядя на экран, отхлёбывает уже холодный кофе) Банк «Арго». Полтора миллиона записей. Три часа. Ну... хоть не в пятницу тринадцатого. Хотя... понедельник, одиннадцать вечера — почти то же самое. Кому я вру."

    "Система мониторинга зафиксировала несанкционированный доступ к основной базе данных банка. До завершения выгрузки остаётся менее трёх часов."

    a "(трёт глаза) Ладно, Алекс, соберись. У тебя диплом магистра, сертификат по кибербезу и хронический недосып. Ты справишься. Наверное."

    menu:
        "Что сделать?"

        "Позвонить в банк":
            jump pozvonit_v_bank

        "Разведать самому":
            jump razvedka


label pozvonit_v_bank:  # спрайты, звук и эффекты звуковые

    $ trust += 1

    "Гудки. Три гудка. Алекс нервно постукивает пальцем по столу."

    "В службе безопасности банка «Арго» трубку снимает Рита."

    r "Служба безопасности «Арго». Рита. У вас тридцать секунд, чтобы объяснить, почему я не должна сбрасывать."

    a "Здравствуйте, Рита. Меня зовут Алекс, я системный аналитик из компании «Киберщит». У нас сработала система мониторинга по вашему банку. Прямо сейчас кто-то качает вашу основную базу данных. И, судя по скорости, этот кто-то очень хочет успеть до утреннего кофе."

    r "Подтверждаю атаку. Странно, моя система молчит... Чёрт. Нет, не молчит, просто уведомления ушли в спам. Прекрасно. Просто прекрасно. Вы можете определить точку входа?"

    a "Мне нужен доступ к вашим логам. Хотя бы частичный."

    r "Даю частичный доступ. Но быстро — у меня тут такое чувство, что через три часа мы все дружно пойдём искать новую работу. (сухо смеётся) Шучу. На самом деле — пойдут искать нас."

    a "Обнадёживает. Вы всегда так мотивируете коллег?"

    r "Только тех, кто звонит в одиннадцать вечера с плохими новостями."

    "Рита говорит коротко и по делу. В её голосе слышна многолетняя усталость."

    jump minigame1_call


label razvedka:  # спрайты, звук и эффекты звуковые

    "Алекс анализирует трафик. На экране мелькают IP-адреса, пакеты данных. Источник явно внутри сети банка. Внезапно в правом нижнем углу появляется окно анонимного чата."

    "Алекс замечает входящее сообщение в защищённом чате. Отправитель не представился."

    n "Ты смотришь не туда."

    a "Так, Алекс, спокойно. Это просто чат. В твоём защищённом рабочем компьютере. В который никто не должен был попасть. {w} Я в полной безопасности. И в полной заднице."

    a "«Ты смотришь не туда». Очень информативно, спасибо, таинственный незнакомец. Прямо fortune cookie для параноиков."

    menu:
        "Что сделать?"

        "Ответить":
            $ dark = True
            jump razgovor

        "Закрыть чат и позвонить в банк":
            $ trust += 1
            jump razvedka_pozvonil


label razvedka_pozvonil:

    a "(решительно закрывая окно чата) Ага, сейчас. «Поговори с незнакомцем в тёмной подворотне», урок ОБЖ, первый класс. Не сегодня, Нуль. (набирает номер банка)"

    "Алекс решает не вступать в диалог с неизвестным и связывается с банком."

    jump minigame1_call



label razgovor:  # спрайты, звук и эффекты звуковые

    a "Чего ты хочешь?"

    n "Не деньги. {w} В архиве банка за 2019 год спрятаны документы о коррупции директора. {w} Меня уволили, когда я об этом сообщил. {w} Помоги добраться до файлов — я уйду."

    a "Уволенный программист, коррупция, архив... {w} Звучит как сюжет для плохого технотриллера. Или для очень хорошего."

    "Неизвестный утверждает, что в архиве банка хранятся документы, способные подтвердить факты коррупции."

    a "Почему я должен тебе верить?"

    n "Я мог слить всё час назад. Полтора миллиона записей, Алекс. {w} Номера счетов, {w} паспорта, {w} кредитные истории. {w} Но я не слил. Я сижу и жду, пока ты разберёшься. {w} Потому что мне не нужны деньги этих людей. {w} Мне нужно, чтобы один конкретный человек перестал спать спокойно."

    menu:
        "Что ответить?"

        "«Хорошо. Расскажи про файлы»":
            $ evidence = True
            a "Хорошо. Расскажи про файлы. И, ради всего святого, скажи, что ты не оставил там пасхалку с танцующим бананом."
            n "(после паузы) Я оставил. Но она зашифрована."
            a "Ты мне уже нравишься."
            "Алекс принимает предложение неизвестного. Теперь у них общая цель."
            jump minigame1_call

        "«Нет. Сообщу в полицию»":
            $ dark = False
            a "Нет. Я сообщу в полицию. Всё, что ты делаешь — незаконно, даже если твоя цель благородна, как диснеевский принц."
            n "Законно — не всегда справедливо. Но ты сам выбрал. Удачи, аналитик."
            "Алекс отказывается от сотрудничества. Неизвестный покидает чат."
            jump minigame1_call


label minigame1_call:

    r "В последнем пакете данных есть зашифрованный фрагмент. Похоже на вызов. Или на подпись. Хакеры любят оставлять автографы, сам знаешь."

    a "(разглядывая буквы) «ЭТНДЬГИЕОНЕИ». Если это чьё-то имя, то родители явно хотели, чтобы ребёнок страдал, заполняя анкеты."

    "В перехваченных данных обнаружена анаграмма. На её расшифровку уходит несколько минут."

    r "Алекс, сосредоточься. У нас два часа пятьдесят... уже сорок семь минут."

    a "Знаю, знаю. Так, если отбросить лишнее... (перетаскивает буквы)"

    $ mg1_result = renpy.call_screen("cipher_screen")

    if mg1_result:
        $ evidence = True
        a "«Это Не Деньги». Это не ограбление. Он что-то ищет."
        r "(тихо) Или кого-то. Продолжай."
    else:
        $ trust -= 1
        a "Чёрт. Не подбирается. Может, там «НЕТ ДЕНЕГ»? Или «ДЕНЬГИ НЕТ»? Ладно, время уходит. Смысл станет ясен позже. Надеюсь."
        "Расшифровать сообщение не удалось. Возможно, его значение прояснится позднее."

    jump act2_start



label act2_start:

    "Алекс на связи с Ритой. На экране — схема сети банка «Арго». Один узел мигает красным."

    "Атака исходит изнутри сети банка. Кто-то использует учётную запись, которая должна была быть заблокирована."

    r "Источник атаки — внутренний IP. Кто-то из бывших сотрудников. Учётная запись не была закрыта после увольнения. Отдел кадров, как всегда, на высоте."

    a "Виктор Орлов. Уволен 14 месяцев назад. Ведущий программист отдела разработки."

    r "(перебирает бумаги) Орлов... Орлов... Так, есть. Он подавал жалобу на директора Саввина. Писал про финансовые махинации, вывод активов, фирмы-однодневки. Жалобу закрыли за отсутствием состава. А его самого уволили через неделю «по сокращению штата»."

    a "Классика. Стукачей никто не любит, даже если они правы."

    r "(сухо) Особенно если они правы."

    a "Значит, он вернулся за доказательствами. Романтик."

    "Виктор Орлов пытался привлечь внимание к нарушениям больше года назад. Теперь он вернулся за документами."

    if evidence:

        a "И судя по логам — нашёл их. Папка /archive/2019/. 47 файлов. Смотрю названия... «Акты_списания_оборудования», «Платёжки_контрагенты», «ООО_Вектор_счета»... Бинго. Это не просто документы, это компромат уровня «все в тюрьму, включая уборщицу»."

        r "(после долгой паузы) Я знала об этом."

        a "Что?"

        r "Знала. Не всё, но догадывалась. Саввин... он умеет убеждать. И умеет пугать. Я молчала, Алекс. Три года молчала."

        "Рита признаётся, что подозревала о нарушениях, но страх заставил её хранить молчание."

    a "(тихо) Рита, сейчас не время для исповедей. У нас хакер внутри сети, и он вот-вот сбежит с файлами. Что будем делать?"

    menu:
        "Что решаешь?"

        "«Нам нужно остановить его. Прямо сейчас.»":
            jump act2_stop_now

        "«Подожди. Сначала посмотрим, что в этих файлах.»":
            jump act2_check_files


label act2_stop_now:

    r "Согласна. Сначала нейтрализуем угрозу, потом разбираемся с моралью."

    jump minigame2_call


label act2_check_files:

    $ evidence = True

    a "Подожди. Сначала посмотрим, что в этих файлах. Если мы его остановим, а окажется, что он прав на все сто — мы просто станем соучастниками сокрытия."

    r "(вздыхает) Ты или очень смелый, или очень глупый. Или и то, и другое одновременно. Ладно. Открывай. Только быстро."

    "Алекс открывает несколько файлов. На экране мелькают сканы платёжек, договоров, схем."

    a "Ого. Ого-го-го. Это не просто махинации. Это учебник «Как украсть банк, не привлекая внимания санитаров». Суммы с семью нулями. Рита, вы там вообще за безопасностью следили или в покер играли?"

    r "(ледяным тоном) Мы следили за внешними угрозами. Внутренние, как видишь, оказались... более творческими."

    "Документы подтверждают факты многолетних хищений. Масштаб нарушений значителен."

    jump minigame2_call


label minigame2_call:

    a "Так, нужно определить, через какой именно канал Орлов проникает в систему. Если я заблокирую не тот узел, мы обрушим половину сети банка, и завтра полгорода не сможет купить кофе в автомате. А это уже гуманитарная катастрофа."

    r "Ты сейчас серьёзно про кофе?"

    a "В два часа ночи? Абсолютно."

    "Для блокировки злоумышленника необходимо точно определить цепочку его проникновения в сеть."

    a "VPN-шлюз... он входит через старую учётку, значит, туннель. Архивный сервер — ну, тут всё очевидно, он читает файлы. Почтовый сервер... (пауза) Ага, умно. Он гоняет через него пустые письма, чтобы создать шум. И сервер логов — конечно, он чистит за собой следы. Прямо как я, когда роняю круассан на клавиатуру."

    r "(смешок) Ты роняешь круассаны на клавиатуру?"

    a "Мы говорим о моих профессиональных навыках, а не о моих отношениях с выпечкой."

    $ mg2_result = renpy.call_screen("match_screen")

    if mg2_result:
        a "Готово. Точка входа найдена. Можно заблокировать без потерь. Орлов, конечно, обидится, но зато банкоматы будут работать."
        "Точка входа определена верно. Блокировка пройдёт без ущерба для остальной инфраструктуры."
    else:
        $ trust -= 1
        a "(нервно) Не то... Не то... Чёрт! Рита, я, кажется, только что отключил систему климат-контроля в серверной."
        r "(обречённо) Там и так жарко."
        a "Извини. Часть файлов уже ушла. Орлов успел скопировать."
        "Допущена ошибка. Часть данных успела покинуть сеть банка."

    jump scene_2_2


label scene_2_2:

    r "Он запустил финальный скрипт выгрузки. Всё, что нашёл в архиве — уходит на внешний сервер. Судя по скорости, у нас меньше пяти минут. Потом — или он исчезает, или мы успеваем."

    a "Понял. Работаю."

    "Алекс открывает консоль. Пальцы зависают над клавиатурой."

    a "(сам себе) Ладно, Виктор Орлов. Ты хорош. Но я играл в «Simon» на телефоне всё детство. Посмотрим, кто кого."

    "До завершения передачи данных остаётся менее пяти минут."

    jump minigame3_call


label minigame3_call:

    r "Скрипт защищён простой последовательностью. Орлов не ожидал, что кто-то доберётся до этого этапа. Самонадеянность — грех."

    a "Или он просто хотел, чтобы мы дошли. Типа финальный босс в видеоигре."

    r "Алекс, меньше разговоров, больше нажиманий на кнопки."

    "Скрипт требует точного повторения команд в заданном порядке. Времени на раздумья почти нет."

    call sequence_minigame

    if mg3_result:
        a "(выдыхает) Есть! Скрипт остановлен. Данные заблокированы. Орлов, извини, твоя посылка не доставлена."
        r "Хорошая работа, аналитик."
        "Выгрузка данных остановлена. Угроза нейтрализована."
    else:
        $ ending_5_unlocked = True
        a "(смотрит на экран) Нет... Нет-нет-нет... Слишком поздно. Часть данных ушла. Орлов получил файлы."
        r "(тихо) Значит, теперь всё решится без нас."
        "Данные скопированы. Злоумышленник достиг своей цели."

    jump act3_start


label act3_start:  # дописать

    return