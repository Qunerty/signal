# Вы можете расположить сценарий своей игры в этом файле.

default trust    = 0
default dark     = False
default evidence = False

# Определение персонажей игры.
define a = Character('Алекс', color="#c8d3ff")

define r = Character('Рита', color="#c8064dad")

define n = Character('Nul', color="#000000ad")



# Вместо использования оператора image можете просто
# складывать все ваши файлы изображений в папку images.
# Например, сцену bg room можно вызвать файлом "bg room.png",
# а eileen happy — "eileen happy.webp", и тогда они появятся в игре.

# Игра начинается здесь:
label start:

    scene bg_office #спрайты звук и эффекты звуковые

    "В офисе компании «Киберщит» тихо. Алекс — единственный, кто остался в ночную смену. На столе перед ним — несколько пустых кружек из-под кофе."

    "Надпись на экране: ⚠ CRITICAL — Unauthorized access detected: ARGO-DB-CORE Time to exfiltration: 02:58:00"

    a "(глядя на экран, отхлёбывает уже холодный кофе) Банк «Арго». Полтора миллиона записей. Три часа. Ну... хоть не в пятницу тринадцатого. Хотя... понедельник, одиннадцать вечера — почти то же самое. Кому я вру."

    "Система мониторинга зафиксировала несанкционированный доступ к основной базе данных банка. До завершения выгрузки остаётся менее трёх часов."

    a "(трёт глаза) Ладно, Алекс, соберись. У тебя диплом магистра, сертификат по кибербезу и хронический недосып. Ты справишься. Наверное."

    menu:
        "Что сделать"

        "позвонить в банк":
            jump pozvonit_v_bank

        "разведать самому":
            jump razvedka

    return

label pozvonit_v_bank: #спрайты звук и эффекты звуковые

    "Гудки. Три гудка. Алекс нервно постукивает пальцем по столу."

    "В службе безопасности банка «Арго» трубку снимает Рита."

    r "Служба безопасности «Арго». Рита. У вас тридцать секунд, чтобы объяснить, почему я не должна сбрасывать."

    a "Здравствуйте, Рита. Меня зовут Алекс, я системный аналитик из компании «Киберщит». У нас сработала система мониторинга по вашему банку. Прямо сейчас кто-то качает вашу основную базу данных. И, судя по скорости, этот кто-то очень хочет успеть до утреннего кофе."

    r "Подтверждаю атаку. Странно, моя система молчит... Чёрт. Нет, не молчит, просто уведомления ушли в спам. Прекрасно. Просто прекрасно. Вы можете определить точку входа?"

    a "Мне нужен доступ к вашим логам. Хотя бы частичный."

    r "Даю частичный доступ. Но быстро — у меня тут такое чувство, что через три часа мы все дружно пойдём искать новую работу. (сухо смеётся) Шучу. На самом деле — пойдут искать нас."

    a "Обнадёживает. Вы всегда так мотивируете коллег?"

    r "Только тех, кто звонит в одиннадцать вечера с плохими новостями."

    "Рита говорит коротко и по делу. В её голосе слышна многолетняя усталость."

    jump minigame1_call

    return

label razvedka: #спрайты звук и эффекты звуковые

    "Алекс анализирует трафик. На экране мелькают IP-адреса, пакеты данных. Источник явно внутри сети банка. Внезапно в правом нижнем углу появляется окно анонимного чата."

    "Алекс замечает входящее сообщение в защищённом чате. Отправитель не представился."

    n "Ты смотришь не туда."

    a "Так, Алекс, спокойно. Это просто чат. В твоём защищённом рабочем компьютере. В который никто не должен был попасть."

    a " "

    a "Я в полной безопасности. И в полной заднице."

    a "«Ты смотришь не туда»."

    a "Очень информативно, спасибо, таинственный незнакомец. Прямо fortune cookie для параноиков."

    menu:
        "ответить незнакомцу"

        "Ответить":
            jump razgovor


        "Закрыть чат и позвонить в банк":
            jump minigame1_call


    return

label razgovor: #спрайты звук и эффекты звуковые

    a "Чего ты хочешь?"

    n "Не деньги. {w} В архиве банка за 2019 год спрятаны документы о коррупции директора. {w} Меня уволили, когда я об этом сообщил. {w} Помоги добраться до файлов — я уйду."

    a "Уволенный программист, коррупция, архив... {w} Звучит как сюжет для плохого технотриллера. Или для очень хорошего."

    "Неизвестный утверждает, что в архиве банка хранятся документы, способные подтвердить факты коррупции."

    a "Почему я должен тебе верить?"

    n "Я мог слить всё час назад. Полтора миллиона записей, Алекс. {w} Номера счетов, {w} паспорта, {w} кредитные истории. {w} Но я не слил. Я сижу и жду, пока ты разберёшься. {w} Потому что мне не нужны деньги этих людей. {w} Мне нужно, чтобы один конкретный человек перестал спать спокойно."


    jump minigame1_call


    return


label minigame1_call:
  $ mg1_result = renpy.call_screen("cipher_screen")
  if mg1_result:
      $ evidence = True
      "Алекс: Это Не Деньги. Он что-то ищет."
  else:
      $ trust -= 1
      "Алекс: Не получилось. Разберёмся позже."
  jump act2_start

label act2_start: #дописать

    return